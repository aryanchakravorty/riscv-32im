// Test program for the final, fixed pipeline.
// This sequence is designed to be comprehensive and test all major features.

@00000000
// 1. ALU Operations
13 08 A0 00 // addi x1, x0, 10
13 08 58 00 // addi x1, x1, 5   (Result: 15)
93 09 58 00 // addi x2, x1, -5  (Result: 10)
13 09 F0 0F // addi x3, x0, 240
13 0A 0F 00 // addi x4, x0, 15
33 09 34 00 // and x3, x3, x4   (Result: 0)
13 09 F0 0F // addi x3, x0, 240
33 0A 34 06 // or x4, x3, x4    (Result: 255)
13 09 AA 00 // addi x3, x0, 170
13 0A 55 00 // addi x4, x0, 85
B3 0A 34 04 // xor x5, x3, x4   (Result: 255)

@0000002C
// 2. Shift Operations
13 0B 10 00 // addi x6, x0, 1
93 8B 4B 00 // slli x6, x6, 4   (Result: 16)
93 0C 2B 05 // srli x7, x6, 2   (Result: 4)
13 0D F0 FF // addi x8, x0, -16
93 0C 2D 45 // srai x8, x8, 2   (Result: -4)

@00000040
// 3. Memory Operations (Load-Use Hazard)
73 00 00 10 // lui x9, 65536 (0x10000) -> loads 0x10000000
03 04 09 00 // lw x9, 0(x9)     (Load from 0x10000000 -> DEADBEEF)
13 05 14 00 // addi x10, x9, 1  (Load-Use Hazard!)

@0000004C
// 4. Branch Operations
13 08 10 00 // addi x1, x0, 1
13 09 10 00 // addi x2, x0, 1
63 00 28 00 // beq x1, x2, +8 (Target: 0x5C)
13 0D 10 00 // addi x11, x0, 0 (Should be skipped)
13 0D 10 00 // addi x11, x0, 1 (Branch lands here)
63 09 28 00 // bne x1, x2, +8 (Not taken)
13 0E 10 00 // addi x12, x0, 0 (Should execute)
13 08 F0 FF // addi x1, x0, -1
63 0C 28 00 // blt x1, x2, +8 (Target: 0x74)
13 0F 10 00 // addi x13, x0, 0 (Should be skipped)
13 0F 10 00 // addi x13, x0, 1 (Branch lands here)
E3 0D 28 04 // bge x1, x2, +8 (Not taken)
13 0A 10 00 // addi x14, x0, 0 (Should execute)

@0000007C
// 5. Jumps
6F 0F 00 00 // jal x15, 0 (Target: 0x7C, RA=0x80) -> This is wrong in a text file, assembler would fix. Let's jump to end.
EF 00 80 00 // jal x16, 128 (Target: 0xFC)
// some space
@000000FC
13 08 10 00 // addi x16, x0, 1 (JALR target)

@00000100
// 6. M-Extension
13 08 70 00 // addi x1, x0, 7
13 09 30 00 // addi x2, x0, 3
B3 08 28 02 // mul x17, x1, x2 (Result: 21)
B3 09 18 02 // mulh x18, x1, x2 (x1 signed, x2 signed)
13 08 40 01 // addi x1, x0, 20
B3 0C 28 06 // div x19, x1, x2 (Result: 2)
B3 0E 28 06 // rem x20, x1, x2 (Result: 6)
13 08 64 00 // addi x1, x0, 100
33 00 08 06 // div x21, x1, x0 (Div by zero)
33 00 08 07 // rem x22, x1, x0 (Rem by zero)

@0000012C
// End of program - infinite loop
6F 00 00 00 // jal x0, 0
